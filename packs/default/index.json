{
  "id": "da.default",
  "name": "DaLang Default Plugins",
  "version": "0.1.0",
  "updateUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/default/index.json",
  "plugins": [
    {
      "id": "da.default.text-selection",
      "name": "Text Selection",
      "version": "0.1.0-yomitan.26.5.19.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "textSelection",
      "description": "Yomitan-based text selection — dom-text-scanner / text-source-* / string-util bundled by CI.",
      "author": "DaLang",
      "hosts": [
        "<all_urls>"
      ],
      "settings": [
        {
          "key": "enabled",
          "type": "bool",
          "label": "Enable text selection",
          "default": true
        },
        {
          "key": "scanLength",
          "type": "int",
          "label": "Scan length",
          "default": 16,
          "min": 1,
          "max": 200
        },
        {
          "key": "scanDelay",
          "type": "int",
          "label": "Scan delay (ms)",
          "default": 20,
          "min": 0,
          "max": 1000
        },
        {
          "key": "scanResolution",
          "type": "choice",
          "label": "Scan resolution",
          "default": "character",
          "options": [
            "character",
            "word"
          ]
        },
        {
          "key": "layoutAwareScan",
          "type": "bool",
          "label": "Layout-aware scan",
          "default": true
        },
        {
          "key": "deepDomScan",
          "type": "bool",
          "label": "Deep DOM scan",
          "default": false
        },
        {
          "key": "normalizeCssZoom",
          "type": "bool",
          "label": "Normalize CSS zoom",
          "default": true
        },
        {
          "key": "scanOnTouchTap",
          "type": "bool",
          "label": "Scan on tap",
          "default": true
        },
        {
          "key": "scanOnTouchMove",
          "type": "bool",
          "label": "Scan on touch drag",
          "default": false
        },
        {
          "key": "sentenceExtent",
          "type": "int",
          "label": "Sentence context length",
          "default": 200,
          "min": 0,
          "max": 1000
        },
        {
          "key": "alphanumeric",
          "type": "bool",
          "label": "Scan non-CJK text",
          "default": true
        },
        {
          "key": "selectText",
          "type": "bool",
          "label": "Highlight selected text",
          "default": true
        },
        {
          "key": "scanWithoutMouseMove",
          "type": "bool",
          "label": "Scan without mouse move",
          "default": true
        }
      ],
      "codeUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/default/plugins/text-selection/script.dap"
    },
    {
      "id": "da.default.subtitle",
      "name": "YouTube Subtitles",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "subtitle",
      "description": "Reads .ytp-caption-segment nodes on YouTube and emits subtitles via da.emit('subtitles'). Pushes on MutationObserver so live captions stream in real time.",
      "author": "DaLang",
      "hosts": [
        "*youtube.com*",
        "*youtu.be*"
      ],
      "settings": [
        {
          "key": "enabled",
          "type": "bool",
          "label": "Enable subtitles",
          "default": true
        },
        {
          "key": "language",
          "type": "choice",
          "label": "Language",
          "options": [
            "ja",
            "zh",
            "ko",
            "en"
          ],
          "default": "ja"
        }
      ],
      "codeUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/default/plugins/subtitle/script.dap"
    },
    {
      "id": "da.default.general",
      "name": "MeCab Furigana",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Annotates visible Japanese text with furigana ruby tags using da.host.mecab.",
      "author": "DaLang",
      "hosts": [
        "<all_urls>"
      ],
      "settings": [
        {
          "key": "enabled",
          "type": "bool",
          "label": "Show furigana",
          "default": true
        }
      ],
      "codeUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/default/plugins/general/script.dap"
    }
  ]
}
