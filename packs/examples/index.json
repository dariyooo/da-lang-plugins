{
  "id": "da.examples",
  "name": "DaLang Examples",
  "version": "0.1.0",
  "updateUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/examples/index.json",
  "plugins": [
    {
      "id": "da.examples.text-selection",
      "name": "Text Selection",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "textSelection",
      "description": "Reference textSelection plugin — exercises all 5 settings types, live settings updates, selection/clear events, and trigger modes.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled",     "type": "bool",   "label": "Enable selection",        "default": true },
        { "key": "minLength",   "type": "int",    "label": "Minimum word length",     "default": 1, "min": 1, "max": 20 },
        { "key": "sensitivity", "type": "double", "label": "Selection sensitivity",   "default": 0.5, "min": 0.1, "max": 1.0 },
        { "key": "prefix",      "type": "string", "label": "Text prefix",             "default": "" },
        { "key": "trigger",     "type": "choice", "label": "Trigger on",              "options": ["mouseup", "selectionchange", "both"], "default": "mouseup" }
      ],
      "codeUrl": "plugins/text-selection/script.dap"
    },
    {
      "id": "da.examples.subtitle",
      "name": "Subtitle Example",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "subtitle",
      "description": "Reference subtitle plugin — demonstrates da.register('get'), da.emit('subtitles'), MutationObserver push, and language tagging.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled",  "type": "bool",   "label": "Enable subtitles", "default": true },
        { "key": "language", "type": "choice", "label": "Language",         "options": ["ja", "zh", "ko", "en"], "default": "ja" }
      ],
      "codeUrl": "plugins/subtitle/script.dap"
    },
    {
      "id": "da.examples.general",
      "name": "General Example",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Reference general plugin — demonstrates DOM modification, da.register for app-callable functions, and da.emit('log').",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "invertColors", "type": "bool",   "label": "Invert page colors",  "default": false },
        { "key": "fontSize",     "type": "int",    "label": "Base font size (px)", "default": 16, "min": 10, "max": 32 },
        { "key": "opacity",      "type": "double", "label": "Page opacity",        "default": 1.0, "min": 0.2, "max": 1.0 },
        { "key": "injectText",   "type": "string", "label": "Banner text",         "default": "" },
        { "key": "theme",        "type": "choice", "label": "Force theme",         "options": ["none", "light", "dark"], "default": "none" }
      ],
      "codeUrl": "plugins/general/script.dap"
    },
    {
      "id": "da.examples.settings-bool",
      "name": "Settings: Bool",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Example plugin with a single bool setting. Toggles a visible banner at the top of the page so the effect of onSettingsChanged is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled", "type": "bool", "label": "Show banner", "default": true }
      ],
      "codeUrl": "plugins/settings-bool/script.dap"
    },
    {
      "id": "da.examples.settings-int",
      "name": "Settings: Int",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Example plugin with a single int setting. Sets the base font size on the page body so the effect of onSettingsChanged is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "fontSize", "type": "int", "label": "Base font size (px)", "default": 16, "min": 8, "max": 32 }
      ],
      "codeUrl": "plugins/settings-int/script.dap"
    },
    {
      "id": "da.examples.settings-double",
      "name": "Settings: Double",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Example plugin with a single double setting. Sets the opacity of the page body so the effect of onSettingsChanged is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "opacity", "type": "double", "label": "Page opacity", "default": 1.0, "min": 0.1, "max": 1.0 }
      ],
      "codeUrl": "plugins/settings-double/script.dap"
    },
    {
      "id": "da.examples.settings-string",
      "name": "Settings: String",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Example plugin with a single string setting. Shows the string in a fixed footer banner so the effect of onSettingsChanged is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "bannerText", "type": "string", "label": "Banner text", "default": "DaLang" }
      ],
      "codeUrl": "plugins/settings-string/script.dap"
    },
    {
      "id": "da.examples.settings-choice",
      "name": "Settings: Choice",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Example plugin with a single choice setting. Applies a light or dark color scheme override to the page so the effect of onSettingsChanged is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "theme", "type": "choice", "label": "Force theme", "options": ["none", "light", "dark"], "default": "none" }
      ],
      "codeUrl": "plugins/settings-choice/script.dap"
    }
  ]
}
